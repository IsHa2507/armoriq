# Copy this to .env for local development (never commit .env)

# Django core — REQUIRED
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — leave blank locally to use SQLite, set on Render for PostgreSQL
DATABASE_URL=

# CORS — set to your Vercel URL in production
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# AI providers — set whichever you use
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── MCP Server requirements ───────────────────────────────────────────────────
# Server 1: notes-server     — CUSTOM   — requires Python 3 (already available)
# Server 2: filesystem-server — CUSTOM  — requires Python 3 (already available)
# Server 3: context7          — REMOTE  — requires Node.js + npx
#
# Context7 is a real public MCP server by Upstash.
# It provides live documentation for any library/framework.
# No API key needed. Install Node.js from https://nodejs.org
# Verify with: node --version && npx --version
# Context7 package: @upstash/context7-mcp (auto-downloaded by npx on first run)
